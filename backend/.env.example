# ============================================================
# Backend Environment Variables — DO NOT commit the real .env
# Copy this file to .env and fill in the actual values.
# ============================================================

# OpenAI
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# AWS (used for S3, Cognito, and other services)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# AWS Cognito (User Authentication)
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=your-cognito-app-client-id
COGNITO_DOMAIN=your-app.auth.us-east-1.amazoncognito.com

# MySQL / Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-db-password-here
DB_NAME_SIGNALVERSE=Store
DB_NAME_BDIB=Store_bdib
DB_NAME_NCHRP=Store_nchrp

# Flask
FLASK_SECRET_KEY=your-flask-secret-key-here
FLASK_ENV=development
FLASK_DEBUG=true

# Allowed Emails (comma-separated)
ALLOWED_EMAILS=user1@example.com,user2@example.com

# OTP Email (Gmail App Password recommended)
# To get an App Password: Google Account → Security → 2-Step Verification → App Passwords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=yourapp@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
